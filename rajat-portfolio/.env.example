# Frontend
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# Backend
ENV=development
API_HOST=0.0.0.0
API_PORT=8000
ALLOWED_ORIGINS=http://localhost:3000
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_API_KEY=your_groq_api_key
SUPABASE_URL=your_supabase_url
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
SUPABASE_DB_URL=postgresql://postgres.<project-ref>:<url-encoded-password>@<region>.pooler.supabase.com:6543/postgres
CONTACT_ADMIN_PASSWORD=set_a_strong_password_for_contact_admin
HUGGINGFACEHUB_API_TOKEN=your_huggingface_token
EMBEDDING_PROVIDER=auto
EMBEDDING_MODEL_NAME=sentence-transformers/all-MiniLM-L6-v2
GEMINI_API_KEY=your_gemini_api_key
GEMINI_EMBEDDING_MODEL=models/gemini-embedding-001
EMBEDDING_DIMENSION=384
PROFILE_MARKDOWN_PATH=app/data/rajat_khandelwal_profile.md
FAISS_STORAGE_PATH=storage/faiss
AUTO_INGEST_ON_STARTUP=true
USE_LOCAL_EMBEDDINGS=true
USE_FAISS=true
